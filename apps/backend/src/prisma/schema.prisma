// ClariFi DB スキーマ
// PostgreSQL使用

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 取引データ（WAONとPayPay統一フォーマット）
// カラムマッピング:
//   date          ← WAON: 取引年月日       / PayPay: 利用日/キャンセル日
//   store         ← WAON: 利用店舗         / PayPay: 利用店名・商品名
//   amount        ← WAON: 利用金額（税込） / PayPay: 支払総額
//   usageType     ← WAON: 利用区分         / PayPay: 支払区分
//   chargeType    ← WAON: チャージ区分     / PayPay: null
//   paymentMethod ← WAON: null             / PayPay: 決済方法
model Transaction {
  id            Int      @id @default(autoincrement())
  date          DateTime                    // 取引年月日 / 利用日
  store         String                      // 利用店舗 / 利用店名・商品名
  amount        Int                         // 利用金額（税込）/ 支払総額
  usageType     String                      // 利用区分 / 支払区分
  chargeType    String?                     // チャージ区分（WAON only, nullable）
  paymentMethod String?                     // 決済方法（PayPay only, nullable）
  category      String   @default("その他") // カテゴリ（自動分類）
  source        String                      // "WAON" or "PAYPAY"
  isExcluded    Boolean  @default(false)    // チャージ・返金・キャンセル除外フラグ
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("transactions")
}

// カテゴリ自動分類ルール
// 店舗名キーワードとカテゴリのマッピング
model CategoryRule {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique               // 例："イオン"
  category  String                         // 例："食費"
  createdAt DateTime @default(now())

  @@map("category_rules")
}

// スクレイピング実行履歴
model ScraperLog {
  id        Int      @id @default(autoincrement())
  source    String                          // "WAON"
  status    String                          // "success" or "error"
  message   String?
  count     Int      @default(0)           // 取得件数
  csvPath   String?                         // 出力CSVパス
  createdAt DateTime @default(now())

  @@map("scraper_logs")
}
