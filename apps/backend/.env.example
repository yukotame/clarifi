# サーバー設定
PORT=3001

# PostgreSQL接続情報
DATABASE_URL="postgresql://ユーザー名:パスワード@localhost:5432/clarifi"

# WAONログイン情報（絶対に実際の値をGitにコミットしないこと）
WAON_LOGIN_ID=your_waon_login_id
WAON_PASSWORD=your_waon_password

# フロントエンドURL（CORS設定用）
FRONTEND_URL=http://localhost:3000

# CSV出力先ディレクトリ
CSV_OUTPUT_DIR=./output
